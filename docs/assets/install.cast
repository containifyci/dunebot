[98.009632, "o", "\""]
[98.044673, "o", "\r\n"]
[98.449698, "o", "  Please go to https://github.com/login/device\r\n  and enter the code:  DUNE-BOTX\r\n"]
[100.255012, "o", "\r\n"]
[102.059861, "o", "  Authorize with a CODEOWNER account.\r\n"]
[103.865248, "o", "  DuneBot stores the token and will use it to approve & merge PRs.\r\n"]
[105.671393, "o", "\r\n"]
[107.477325, "o", "\r\n\u001b[1;36m── Step 5 · Add .github/dunebot.yaml to a repository ──────────────────────────────────\u001b[0m\r\n"]
[108.283212, "o", "  A minimal config that auto-approves Dependabot PRs:\r\n"]
[110.088742, "o", "\r\n"]
[111.897757, "o", "  version: 1.0.0\r\n\r\n  approve:\r\n    approver: \"your-bot-username\"\r\n    include:\r\n      - authors:\r\n        - \"dependabot[bot]\"\r\n    required_statuses:\r\n      - \"ci/circleci: build\"\r\n\r\n  merge:\r\n    method: squash\r\n    include:\r\n      - authors:\r\n        - \"dependabot[bot]\"\r\n"]
[111.898242, "o", "\r\n"]
[113.703054, "o", "\r\n\u001b[1;36m── Step 6 · Verify with a test Pull Request ──────────────────────────────────\u001b[0m\r\n"]
[114.508752, "o", "  Open a Dependabot PR, then watch the logs:\r\n"]
