[84.70111, "o", "p"]
[84.736413, "o", "s"]
[84.77167, "o", "\r\n"]
[85.177032, "o", "NAME                 IMAGE               STATUS         PORTS\r\ndunebot-app-1        dunebot-app         Up (healthy)   0.0.0.0:8080->8080/tcp\r\ndunebot-token-1      dunebot-token       Up             0.0.0.0:50051->50051/tcp, 0.0.0.0:8081->8080/tcp\r\n"]
[86.982481, "o", "\r\n\u001b[1;36m── Step 4 · Connect a code-owner account ──────────────────────────────────\u001b[0m\r\n"]
[87.787997, "o", "  Open in a browser:\r\n"]
[89.593552, "o", "    https://<your-host>/app/github/setup?installation_id=<id>\r\n"]
[91.399165, "o", "\r\n"]
[93.204039, "o", "  DuneBot runs the GitHub OAuth device flow and shows a code:\r\n"]
[95.009756, "o", "\r\n"]
[96.815466, "o", "\u001b[32m$\u001b[0m e"]
[96.851324, "o", "c"]
[96.886288, "o", "h"]
[96.921572, "o", "o"]
