[16.251694, "o", "    3. Deploy with Docker Compose\r\n"]
[18.057508, "o", "    4. Connect a code-owner account\r\n"]
[19.863232, "o", "    5. Add a dunebot.yaml to a repository\r\n"]
[21.668799, "o", "    6. Verify with a test Pull Request\r\n"]
