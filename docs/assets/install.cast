[3.615059, "o", "  ║          DuneBot — Installation Walkthrough                  ║\r\n"]
[5.420663, "o", "  ║   Set up DuneBot for a private GitHub organization           ║\r\n"]
[7.226168, "o", "  ╚══════════════════════════════════════════════════════════════╝\r\n"]
[9.031383, "o", "\r\n"]
[10.836903, "o", "  This recording covers the terminal portions of the install:\r\n"]
[12.64236, "o", "    1. Clone the repository\r\n"]
