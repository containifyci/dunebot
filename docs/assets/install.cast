[37.984768, "o", "\r\n"]
[39.79018, "o", "  Edit .env and fill in the values from your GitHub App:\r\n"]
[41.595566, "o", "\r\n"]
[43.401041, "o", "    DUNEBOT_GITHUB_APP_INTEGRATION_ID          = <App ID>\r\n"]
[45.206616, "o", "    DUNEBOT_GITHUB_APP_PRIVATE_KEY             = <base64 of the .pem>\r\n"]
[47.012677, "o", "    DUNEBOT_GITHUB_APP_WEBHOOK_SECRET          = <webhook secret>\r\n"]
[48.817772, "o", "    DUNEBOT_GITHUB_OAUTH_CLIENT_ID             = <Client ID>\r\n"]
[50.623447, "o", "    DUNEBOT_GITHUB_OAUTH_CLIENT_SECRET         = <Client Secret>\r\n"]
[52.428915, "o", "    DUNEBOT_APP_CONFIGURATION_INSTALLATION_ID  = <installation id>\r\n"]
