[72.933001, "o", "\r\n"]
[73.338296, "o", "[+] Running 5/5\r\n ✔ app    Built                                 0.0s\r\n ✔ token  Built                                 0.0s\r\n ✔ Network dunebot_mynet  Created               0.1s\r\n ✔ Container dunebot-app-1    Started           0.3s\r\n ✔ Container dunebot-token-1  Started           0.3s\r\n"]
[75.143844, "o", "\r\n"]
[76.949745, "o", "  Two services start:\r\n"]
[78.755545, "o", "    • app   — DuneBot server (webhooks + dashboard) on :8080\r\n"]
[80.56111, "o", "    • token — JWT token service on :50051 (gRPC) & :8081 (HTTP)\r\n"]
[82.366354, "o", "\r\n"]
[84.171997, "o", "\u001b[32m$\u001b[0m d"]
[84.207361, "o", "o"]
[84.242833, "o", "c"]
